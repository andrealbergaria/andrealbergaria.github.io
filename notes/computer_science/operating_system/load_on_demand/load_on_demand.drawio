        <mxCell id="vZdKvlcUHhhbrESE6Tve-70" parent="1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;" value="&lt;div&gt;Loads func1 into memory.&lt;/div&gt;" vertex="1">
          <mxGeometry height="134" width="134" x="403.25" y="-738.5" as="geometry" />
        </mxCell>
        <mxCell id="vZdKvlcUHhhbrESE6Tve-71" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;&lt;font style=&quot;color: rgb(255, 0, 0); font-size: 15px;&quot;&gt;Process address space and kernel space&lt;/font&gt;&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="319" x="196.75" y="-401" as="geometry" />
        </mxCell>
        <mxCell id="vZdKvlcUHhhbrESE6Tve-73" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="According to chat GPT,&lt;div&gt;&quot;This design avoids changing page tables on every system call or interrupt, which was historically expensive because it required flushing the TLB.&quot;&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="382" x="176.5" y="229" as="geometry" />
        </mxCell>
        <mxCell id="vZdKvlcUHhhbrESE6Tve-74" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="With this system (load on demand), possibliy, there wont be too costly, to put / take pages into&amp;nbsp; / , out of memory" vertex="1">
          <mxGeometry height="30" width="324" x="213.25" y="311" as="geometry" />
        </mxCell>
        <mxCell id="vZdKvlcUHhhbrESE6Tve-75" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;font-size: 15px; color: rgb(255, 0, 0);&quot;&gt;&lt;b&gt;RAM needed&lt;/b&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="30" width="387" x="162.75" y="477" as="geometry" />
        </mxCell>
