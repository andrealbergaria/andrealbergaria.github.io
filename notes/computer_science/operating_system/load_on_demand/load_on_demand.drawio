        <mxCell id="vZdKvlcUHhhbrESE6Tve-20" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="kernel space (mappings)&amp;nbsp;" vertex="1">
          <mxGeometry height="69" width="120" x="185.5" y="-267" as="geometry" />
        </mxCell>
        <mxCell id="vZdKvlcUHhhbrESE6Tve-21" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="Process space (user space)" vertex="1">
          <mxGeometry height="60" width="120" x="185.5" y="-198" as="geometry" />
        </mxCell>
        <mxCell id="vZdKvlcUHhhbrESE6Tve-22" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="On process 1 and 2, the kernel space, is part of process address space. Why do we call it kernel space? Usually kernel space, is where you load / execute instructions, that are used / belong to kernel. Also , kernel space, is different either we use process addresses kernel space, or use the actualy kernel reserved memory. If you access the kernel space on process address space, youre accessing both&amp;nbsp; process memory, and kernel memory. So on processes instead of using kernel space, use pointers to actualy kernel memory? Not using kernel space on process, frees a lot of address space..." vertex="1">
          <mxGeometry height="30" width="536" x="79.75" y="67" as="geometry" />
        </mxCell>
        <mxCell id="vZdKvlcUHhhbrESE6Tve-24" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="Process 1 address space" vertex="1">
          <mxGeometry height="30" width="183" x="159.5" y="-309" as="geometry" />
        </mxCell>
        <mxCell id="vZdKvlcUHhhbrESE6Tve-25" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="Real kernel memory area (should be shared)" vertex="1">
          <mxGeometry height="60" width="120" x="408.5" y="-89" as="geometry" />
        </mxCell>
        <mxCell id="vZdKvlcUHhhbrESE6Tve-26" edge="1" parent="1" source="vZdKvlcUHhhbrESE6Tve-21" style="endArrow=classic;html=1;rounded=0;" value="">
